{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "provider": {
    "Tencent-Deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Tencent-Deepseek",
      "options": {
        "baseURL": "https://api.lkeap.cloud.tencent.com/v1"
      },
      "models": {
        "deepseek-v3.2": {
          "name": "Deepseek-Reasoner",
          "cost": {
            "input": 2,
            "output": 3
          },
          "limit": {
            "context": 128000,
            "input": 96000,
            "output": 32000
          },
          "options": {
            "enable_search": false,
            "thinking": {
              "type": "enabled"
            }
          }
        }
      }
    },
    "bailian-coding-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Bailian Coding Plan",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "sk-sp-105b78e7f3844d09bf99a97fef4dae01"
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "options": {
            "thinking": {
              "type": "enabled",
            }
          }
        },
        "glm-4.7": {
          "name": "GLM-4.7",
          "options": {
            "thinking": {
              "type": "enabled",
            }
          }
        },
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus"
        },
      }
    }
  },
  "mcp": {
    "jupyter": {
      "type": "local",
      "command": ["uvx", "jupyter-mcp-server@latest"],
      "environment": {
        "JUPYTER_URL": "http://192.168.2.160:8888",
        "JUPYTER_TOKEN": "{env:JUPYTER_TOKEN}",
        "ALLOW_IMG_OUTPUT": "true"
      },
      "enabled": false
    }
  }
}
