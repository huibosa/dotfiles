{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "oh-my-opencode@latest"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4"
    },
    "plan": {
      "model": "lkeap/kimi-k2.5"
    },
    "explore": {
      "model": "lkeap/kimi-k2.5"
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "Tencent-Deepseek-API": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Tencent Deepseek API",
      "options": {
        "baseURL": "https://api.lkeap.cloud.tencent.com/v1"
      },
      "models": {
        "deepseek-v3.2": {
          "name": "Deepseek Reasoner",
          "options": { "thinking": { "type": "enabled" }
          }
        }
      }
    },
    "Tencent-Cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Tencent Cloud",
      "options": {
        "baseURL": "https://api.lkeap.cloud.tencent.com/v3"
      },
      "models": {
        "glm-5": {
          "name": "GLM 5",
          "options": { "thinking": { "type": "enabled" } }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": { "input": [ "text", "image" ], "output": [ "text" ] },
          "options": { "thinking": { "type": "enabled" } }
        }
      }
    },
    "lkeap": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "lkeap",
      "options": {
        "baseURL": "https://api.lkeap.cloud.tencent.com/coding/v3"
      },
      "models": {
        "minimax-m2.5": {
          "name": "MiniMax-M2.5",
          "modalities": { "input": [ "text" ], "output": [ "text" ] },
          "options": { "thinking": { "type": "enabled", "budgetTokens": 8192 } },
          "limit": { "context": 196608, "output": 32768 }
        },
        "glm-5": {
          "name": "GLM 5",
          "options": { "thinking": { "type": "enabled" }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": { "input": [ "text", "image" ], "output": [ "text" ] },
          "options": { "thinking": { "type": "enabled" }
          }
        }
      }
    },
    "aigc": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "aigc",
      "options": {
        "baseURL": "https://text-aigc.vod-qcloud.com/v1"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1000000,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking_enabled": true,
            // "reasoningEffort": "xhigh"
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "minimal": {
              "reasoningEffort": "minimal",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            }
          }
        },
        "gemini-3.1-pro-preview" : {
          "name": "Gemini-3.1-Pro-Preview",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking_enabled": true
          },
          "variants": {
            "minimal": {
              "reasoningEffort": "minimal",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            }
          }
        }
      }
    }
  }
}
