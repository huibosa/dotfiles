{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "background_task": {
    "staleTimeouts": 1800000,
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 5
    }
  },
  "agents": {
    // Main orchestrator: Claude Opus or Kimi K2.5 work best
    "sisyphus": { "model": "lkeap/kimi-k2.5", "temperature": 0.1 },

    // Research agents: cheaper models are fine
    "librarian": { "model": "lkeap/kimi-k2.5", "variant": "low" },
    "explore": { "model": "lkeap/kimi-k2.5", "variant": "low" },

    // Architecture consultation: GPT or Claude Opus
    "oracle": { "model": "openai/gpt-5.4", "variant": "high", "temperature": 0.1 },

    // Prometheus inherits sisyphus model; just add prompt guidance
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "temperature": 0.1,
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel."
    },

    "hephaestus": { "model": "openai/gpt-5.3-codex", "variant": "high", "temperature": 0.1 },
    "metis": { "model": "openai/gpt-5.4", "temperature": 0.3 },
    "momus": { "model": "openai/gpt-5.4", "variant": "xhigh", "temperature": 0.1 },
    "atlas": { "model": "lkeap/kimi-k2.5", "temperature": 0.1 },

    "multimodal-looker": { "model": "lkeap/kimi-k2.5", "variant": "medium" }
  },
  "categories": {
    "quick": { "model": "lkeap/glm-5", "variant": "low", "temperature": 0.1 },
    "deep": { "model": "openai/gpt-5.3-codex", "variant": "medium", "temperature": 0.1 },
    "ultrabrain": { "model": "openai/gpt-5.3-codex", "variant": "xhigh", "temperature": 0.1 },
    "unspecified-low": { "model": "lkeap/glm-5", "temperature": 0.1 },
    "unspecified-high": { "model": "openai/gpt-5.4", "variant": "high", "temperature": 0.1 },
    "writing": { "model": "lkeap/kimi-k2.5", "variant": "medium", "temperature": 0.2 },
    "visual-engineering": { "model": "lkeap/kimi-k2.5", "variant": "medium", "temperature": 0.1 },

    "git": {
      "model": "lkeap/kimi-k2.5",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  }
}
